# Add these Redis configuration variables to your .env file:

# Redis Configuration
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_TLS=false

# Example configurations for different providers:

# Redis Labs / Redis Cloud
# REDIS_HOST=redis-12345.c123.us-east-1-2.ec2.cloud.redislabs.com
# REDIS_PORT=12345
# REDIS_PASSWORD=your-redis-password
# REDIS_TLS=true

# Render Redis
# REDIS_HOST=your-app-name-redis
# REDIS_PORT=6379
# REDIS_PASSWORD=your-render-redis-password
# REDIS_TLS=false

# Railway Redis
# REDIS_HOST=containers-us-west-123.railway.app
# REDIS_PORT=6123
# REDIS_PASSWORD=your-railway-redis-password
# REDIS_TLS=false

# Local Redis (for development)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false